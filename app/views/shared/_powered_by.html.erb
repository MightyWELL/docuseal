<div class="text-center px-2">
  <% if local_assigns[:with_counter] %>
    <% count = CompletedSubmitter.distinct.count(:submission_id) %>
    <% if count > 1 %>
      <%= t('count_documents_signed_with_html', count:) %>
    <% else %>
      <%= t('powered_by') %>
    <% end %>
  <% else %>
    <%= t('powered_by') %>
  <% end %>
  <%# §7(b) attribution: DocuSeal credit retained here (do not remove). %>
  <a href="https://www.docuseal.com<%= local_assigns[:link_path] %>" class="underline" target="_blank" rel="noopener">DocuSeal</a> - <%= t('open_source_documents_software') %>
</div>
