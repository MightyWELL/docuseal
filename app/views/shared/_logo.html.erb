<%# MightyWELL mark. Square icon; respects :width/:height when given, else uses :class sizing. %>
<% if local_assigns[:width] || local_assigns[:height] %>
  <%= image_tag '/mw-mark.png', alt: 'MightyWELL', class: local_assigns[:class],
        style: "height: #{local_assigns.fetch(:height, '37').to_s.sub(/px$/, '')}px; width: #{local_assigns.fetch(:width, '37').to_s.sub(/px$/, '')}px;" %>
<% else %>
  <%= image_tag '/mw-mark.png', alt: 'MightyWELL', class: local_assigns.fetch(:class, 'h-9 w-9') %>
<% end %>
